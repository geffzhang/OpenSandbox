{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenClaw": {
    "DatabasePath": "data/openclaw.db",
    "CookieName": "openclaw.session",
    "ApiKeyEncryptionKey": "change-this-key"
  },
  "AdminBootstrap": {
    "UserNameEnv": "OPENCLAW_ADMIN_USERNAME",
    "PasswordEnv": "OPENCLAW_ADMIN_PASSWORD",
    "DisplayNameEnv": "OPENCLAW_ADMIN_DISPLAY_NAME"
  }
}
