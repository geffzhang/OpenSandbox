{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenSandbox": {
    "Tokens": [
      "dev-sandbox-key"
    ],
    "CleanupIntervalSeconds": 30,
    "ProxyUpstreamHost": "127.0.0.1",
    "EndpointHost": null,
    "Proxy": {
      "ActivityTimeoutMinutes": 10
    }
  },
  "Runtime": {
    "Type": "docker"
  },
  "DockerRuntime": {
    "DockerCommand": "docker",
    "PublishedPorts": [
      80,
      443,
      3000,
      4173,
      5000,
      5050,
      5173,
      8000,
      8080,
      8081,
      8787,
      18789
    ]
  },
  "KubernetesRuntime": {
    "Namespace": "opensandbox",
    "CrdGroup": "sandbox.opensandbox.io",
    "CrdVersion": "v1alpha1",
    "CrdPlural": "batchsandboxes",
    "PoolName": null,
    "ExecdImage": null,
    "ExecdPort": 44772,
    "EgressSidecarPort": 18080,
    "EndpointsAnnotationKey": "sandbox.opensandbox.io/endpoints",
    "WatchTimeoutSeconds": 300
  },
  "FileSystemStore": {
    "StorePath": "data/sandboxes.json"
  }
}
